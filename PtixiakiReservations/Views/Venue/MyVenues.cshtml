@model IEnumerable<PtixiakiReservations.Models.Venue>

@{
    ViewData["Title"] = "My Venues";
}

@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 12;
    string currentFilter = ViewBag.CurrentFilter ?? Context.Request.Query["filter"].ToString();
    if (string.IsNullOrEmpty(currentFilter)) currentFilter = "mine";
}

<div class="bg-gray-50 min-h-screen py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
        <!-- Page Header -->
        <div class="bg-white rounded-xl shadow-md overflow-hidden mb-8">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-8 md:flex md:items-center md:justify-between">
                <div>
                    <h1 class="text-2xl md:text-3xl font-bold text-white">
                        Venues
                    </h1>
                    <p class="mt-2 text-blue-100 max-w-3xl">
                        Manage your venues and their settings
                    </p>
                </div>

                <div class="mt-4 md:mt-0 flex flex-col sm:flex-row items-center gap-4">
                    <!-- The Dropdown -->
                    <select onchange="updateUrl('filter', this.value)" 
                            class="block w-full sm:w-auto pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-2 focus:ring-white focus:border-white sm:text-sm rounded-md shadow-sm bg-white text-gray-700">
                        @if (currentFilter == "all")
                        {
                            <option value="mine">My Venues</option>
                            <option value="all" selected>All Venues</option>
                        }
                        else
                        {
                            <option value="mine" selected>My Venues</option>
                            <option value="all">All Venues</option>
                        }
                    </select>

                    <!-- The Add Button -->
                    <a href="@Url.Action("Create", "Venue")"
                       class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-indigo-700 bg-white hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-sm transition-colors w-full sm:w-auto justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                        Add New Venue
                    </a>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="bg-white px-6 py-4 border-b border-gray-200">
                <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 h-10 w-10 rounded-md bg-blue-100 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-gray-500">@(currentFilter == "all" ? "Total Venues" : "My Venues")</p>
                            <p class="text-lg font-semibold text-gray-900">@(ViewBag.TotalCount ?? Model.Count())</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="flex-shrink-0 h-10 w-10 rounded-md bg-green-100 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-gray-500">Cities</p>
                            <p class="text-lg font-semibold text-gray-900">@(ViewBag.CityCount ?? Model.Select(v => v.City.Name).Distinct().Count())</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="flex-shrink-0 h-10 w-10 rounded-md bg-purple-100 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-gray-500">Events</p>
                            <p class="text-lg font-semibold text-gray-900">@(ViewBag.EventCount ?? 0)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-between mb-8">
            <select id="variable-pagination" onchange="updateUrl('pageSize', this.value)" class="appearance-none bg-white border border-gray-300 rounded-lg py-2 px-4 pr-8 leading-tight focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors w-[150px] text-sm">
                <option value="12" selected="@(pageSize == 12)">12 per page</option>
                <option value="24" selected="@(pageSize == 24)">24 per page</option>
                <option value="36" selected="@(pageSize == 36)">36 per page</option>
            </select>
        </div>

        <!-- Venue Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var item in Model)
            {
                var subAreaCount = 0;
                string imagePath = "~/images/image.jpg"; // Default fallback

                if (ViewBag.SubAreaCounts != null && ViewBag.SubAreaCounts.ContainsKey(item.Id))
                {
                    subAreaCount = ViewBag.SubAreaCounts[item.Id];
                }

                if (ViewBag.ImagePaths != null && ViewBag.ImagePaths.ContainsKey(item.Id))
                {
                    imagePath = ViewBag.ImagePaths[item.Id];
                }

                <div class="group bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-all duration-200 transform hover:-translate-y-1">
                    <!-- Image with overlay -->
                    <div class="relative h-48 w-full overflow-hidden">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                             src="@imagePath" 
                             asp-append-version="true" 
                             alt="@item.Name" />

                        <!-- City badge -->
                        <div class="absolute top-0 right-0 mt-3 mr-3 bg-white bg-opacity-90 text-indigo-800 text-xs font-bold px-2 py-1 rounded-full shadow-sm">
                            @item.City.Name
                        </div>

                        <!-- Sub-areas count badge -->
                        <div class="absolute bottom-0 left-0 mb-3 ml-3 bg-purple-600 text-white text-xs font-bold px-2 py-1 rounded-full shadow-sm flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                            </svg>
                            @subAreaCount areas
                        </div>
                    </div>

                    <!-- Venue Info -->
                    <div class="p-5">
                        <h3 class="text-lg font-semibold text-gray-800 mb-2 truncate">
                            @item.Name
                        </h3>

                        <!-- Location and Contact Info -->
                        
                        <div class="flex items-start">
                            <svg class="h-5 w-5 text-gray-500 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z"></path>
                            </svg>
                            <p class="text-sm text-gray-600 leading-snug">
                                @if (item.VenueCategory != null && item.VenueCategory.Any())
                                {
                                    @foreach (var category in item.VenueCategory.Where(c => c.CategoryId != null))
                                    {
                                        @if (category.CategoryId != null){
                                            <span class="whitespace-nowrap px-2 py-1 bg-indigo-100 text-indigo-800 text-xs rounded-full">
                                                @category.EventType.Name 
                                            </span>
                                        }
                                    }
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-indigo-100 text-indigo-800 text-xs rounded-full">All</span>
                                }
                            </p>
                        </div>

                        <!-- Location and Contact Info -->
                        <div class="space-y-2 mb-4">
                            <div class="flex items-start">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500 mt-0.5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                </svg>
                                <p class="text-sm text-gray-600 leading-snug">
                                    @item.Address, @item.PostalCode
                                </p>
                            </div>

                            <div class="flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                                <p class="text-sm text-gray-600">
                                    @item.Phone
                                </p>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
                                View Details
                                <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </a>

                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="inline-flex items-center text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Edit
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="mt-12 flex justify-center">
                <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                    @if (currentPage > 1)
                    {
                        <a href="@Url.Action("MyVenues", new { page = currentPage - 1, filter = currentFilter, pageSize = pageSize })"
                           class="pagination-prev relative inline-flex items-center px-4 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                            <span class="sr-only">Previous</span>
                            <svg class="h-5 w-5 mr-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                            </svg>
                            Previous
                        </a>
                    }

                    @{
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, startPage + 4);
                        if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
                    }

                    @if (startPage > 1)
                    {
                        <a href="@Url.Action("MyVenues", new { page = 1, filter = currentFilter, pageSize = pageSize })" 
                           class="page-number pagination-link relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">1</a>
                        @if (startPage > 2)
                        {
                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">...</span>
                        }
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a href="@Url.Action("MyVenues", new { page = i, filter = currentFilter, pageSize = pageSize })"
                           class="page-number pagination-link @(i == currentPage ? "active current-page z-10 bg-indigo-50 border-indigo-500 text-indigo-600" : "bg-white border-gray-300 text-gray-500 hover:bg-gray-50") relative inline-flex items-center px-4 py-2 border text-sm font-medium">
                            @i
                        </a>
                    }

                    @if (endPage < totalPages)
                    {
                        @if (endPage < totalPages - 1)
                        {
                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">...</span>
                        }
                        <a href="@Url.Action("MyVenues", new { page = totalPages, filter = currentFilter, pageSize = pageSize })" 
                           class="page-number pagination-link relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">@totalPages</a>
                    }

                    @if (currentPage < totalPages)
                    {
                        <a href="@Url.Action("MyVenues", new { page = currentPage + 1, filter = currentFilter, pageSize = pageSize })"
                           class="pagination-next relative inline-flex items-center px-4 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                            Next
                            <svg class="h-5 w-5 ml-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                            </svg>
                        </a>
                    }
                </nav>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-12">
                <div class="mx-auto h-24 w-24 text-gray-400 mb-4">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-full w-full">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                </div>
                <h3 class="mt-4 text-sm font-medium text-gray-900">No venues</h3>
                <p class="mt-1 text-sm text-gray-500">Get started by creating your first venue.</p>
                <div class="mt-6">
                    <a href="@Url.Action("Create", "Venue")"
                       class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                        Add New Venue
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function updateUrl(param, value) {
            const url = new URL(window.location.href);
            url.searchParams.set(param, value);
            if (param !== 'page') {
                url.searchParams.set('page', '1');
            }
            window.location.href = url.href;
        }
    </script>
}