@model PtixiakiReservations.Models.Event

@{
    ViewData["Title"] = "Create New Event";
}

<div class="bg-gradient-to-r from-blue-50 to-indigo-50 min-h-screen py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-xl shadow-md overflow-hidden mb-8">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-8">
                <h1 class="text-2xl md:text-3xl font-bold text-white">Create New Event</h1>
                <p class="mt-2 text-indigo-100 max-w-3xl">
                    Schedule new events for your venue, set up recurring events or create single instances
                </p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <div class="p-6">
                <form asp-action="CreateEvent" asp-controller="Events" method="post" id="createEventForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="space-y-6">
                        

                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                            <div class="flex items-center mb-4">
                                <div class="h-10 w-10 rounded-md bg-indigo-100 flex items-center justify-center text-indigo-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                </div>
                                <h2 class="ml-3 text-lg font-medium text-gray-800">Event Mode</h2>
                            </div>

                            <div class="bg-indigo-600 rounded-lg p-1 mb-2 flex shadow-inner">
                                <label class="flex-1 text-center py-2 cursor-pointer transition-all rounded-md bg-white shadow-sm" id="labelFather">
                                    <input type="radio" id="radioFather" name="eventMode" value="father" class="sr-only" checked onchange="toggleEventMode('father')">
                                    <span class="text-indigo-700 font-bold">Master Event</span>
                                </label>

                                <label class="flex-1 text-center py-2 cursor-not-allowed transition-all rounded-md opacity-50 pointer-events-none" id="labelChild" title="You must create a Master Event first!">
                                    <input type="radio" id="radioChild" name="eventMode" value="child" class="sr-only" disabled onchange="toggleEventMode('child')">
                                    <span class="text-white font-medium flex items-center justify-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                        </svg>
                                        Sub-Event (Child)
                                    </span>
                                </label>
                            </div>

                            <p id="parentUnlockHelperText" class="text-sm text-indigo-500 font-medium mt-1 text-right italic">
                                * Create a Master Event first to unlock Sub-Events
                            </p>
                        </div>


                        <div id="parentEventSection" class="hidden bg-gray-50 rounded-lg p-4 border border-gray-200">
                            <h2 class="text-lg font-medium text-gray-800 mb-4">Parent Event Selection</h2>
                            <input type="hidden" asp-for="ParentEventId" id="ParentEventId" name="ParentEventId" />
                            <div class="search-container relative max-w-md">
                                <label class="text-sm font-medium text-gray-700">Search Father Event</label>
                                <div class="flex gap-2">
                                    <input type="text" id="parentEventSearch" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white" placeholder="Start typing..." autocomplete="off" />
                                    <button class="px-4 py-2 bg-gray-200 rounded-md text-sm hidden" type="button" id="clearParentSelection">Clear</button>
                                </div>
                                <ul id="searchResults" class="absolute w-full bg-white border rounded-b-lg shadow-xl z-50 hidden max-h-60 overflow-y-auto"></ul>
                            </div>
                            <p id="parentRequiredError" class="text-red-500 text-xs mt-2 hidden font-bold">You must select a father event to continue in child mode!</p>
                        </div>


                        <div id="subEventsListContainer" class="hidden mt-6 bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
                            <div class="bg-indigo-50 px-6 py-4 border-b border-indigo-100 flex justify-between items-center">
                                <div>
                                    <h3 class="text-indigo-800 font-bold text-sm">Sub-Events Created (<span id="subEventCountDisplay">0</span>)</h3>
                                    <p class="text-[10px] text-indigo-600">Instances tied to this Master Event</p>
                                </div>

                                <button type="button" onclick="showChildEventForm()" class="p-1.5 bg-indigo-600 text-white rounded-full hover:bg-indigo-700 shadow-sm transition-transform hover:scale-110" title="Add another sub-event">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v6h4a1 1 0 110 2h-4v6a1 1 0 11-2 0v-6H4a1 1 0 110-2h4V4a1 1 0 011-1z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                            </div>
                            <div class="max-h-48 overflow-y-auto">
                                <table class="min-w-full divide-y divide-gray-200">
                                    <thead class="bg-gray-50 text-[10px] uppercase font-bold text-gray-500">
                                        <tr>
                                            <th class="px-6 py-2 text-left">Event Name</th>
                                            <th class="px-6 py-2 text-left">Date & Time</th>
                                            <th class="px-6 py-2 text-left">Layout</th>
                                            <th class="px-6 py-2 text-right">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="subEventsTableBody" class="divide-y divide-gray-100 text-sm">

                                    </tbody>
                                </table>
                            </div>
                        </div>


                        <div id="eventDetailsWrapper" class="space-y-6">
                            
   
                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mt-6">
                                <h3 class="text-md font-medium text-gray-700 mb-4">Event Details</h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div>
                                        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Event Name</label>
                                        <input asp-for="Name" placeholder="Enter event name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500"/>
                                        <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
                                    </div>
                                    <div>
                                        <label asp-for="EventTypeId" class="block text-sm font-medium text-gray-700 mb-1">Event Type</label>
                                        <select asp-for="EventTypeId" asp-items="ViewBag.EventTypeList" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white"></select>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-6">
                                <label class="block text-sm font-medium text-gray-700 mb-1">Event Poster</label>
                                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg bg-white">
                                    <div class="text-center">
                                        <label for="imageFile" class="cursor-pointer font-medium text-indigo-600">
                                            <span>Upload a file</span>
                                            <input id="imageFile" name="imageFile" type="file" class="sr-only" accept="image/*" onchange="previewImage(this)">
                                        </label>
                                        <p id="childImageNote" class="hidden text-indigo-500 text-xs italic mt-1">Inherits Father's image if left empty</p>
                                    </div>
                                </div>
                                <div id="imagePreviewContainer" class="hidden mt-4">
                                    <img id="imagePreview" src="#" class="h-32 w-auto rounded-lg shadow-sm border">
                                </div>
                            </div>

                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Venue</label>
                                        <input type="hidden" asp-for="VenueId" id="VenueId" />
                                        <div class="search-container relative">
                                            <div class="flex gap-2">
                                                <input type="text" id="venueSearch" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white disabled:bg-gray-100 disabled:text-gray-400" placeholder="Search for a venue..." autocomplete="off" />
                                                <button class="px-4 py-2 bg-gray-200 rounded-md text-sm hidden" type="button" id="clearVenueSelection">Clear</button>
                                            </div>
                                            <ul id="venueSearchResults" class="absolute w-full bg-white border rounded-b-lg shadow-xl z-50 hidden max-h-60 overflow-y-auto"></ul>
                                        </div>
                                    </div>
                                    <div>
                                        <label asp-for="SubAreaId" class="block text-sm font-medium text-gray-700 mb-1">Sub Area</label>
                                        <select asp-for="SubAreaId" id="subAreaSelect" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white disabled:bg-gray-100" required>
                                            <option value="">Select a sub area</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                                <div id="multiDayToggleContainer" class="flex items-center mb-6">
                                    <input type="checkbox" id="isMultiDay" name="IsMultiDay" class="h-5 w-5 text-indigo-600 border-gray-300 rounded">
                                    <label for="isMultiDay" class="ml-3 font-medium text-gray-700">Create events for multiple days</label>
                                </div>

                                <div id="singleDayContainer" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <input asp-for="StartDateTime" type="datetime-local" class="w-full border p-2 rounded-lg disabled:bg-gray-100" />
                                    <input asp-for="EndTime" type="datetime-local" class="w-full border p-2 rounded-lg disabled:bg-gray-100" />
                                </div>

                                <div id="multiDayContainer" class="hidden space-y-6">
                                    <input asp-for="StartDateTime" type="hidden" id="multiStartDateTime" />
                                    <input asp-for="EndTime" type="hidden" id="multiEndDateTime" />
                                    <div class="grid grid-cols-2 gap-4">
                                        <input id="StartDate" name="StartDate" type="date" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                        <input id="EndDate" name="EndDate" type="date" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                        <input id="StartTime" name="StartTime" type="time" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                        <input id="DailyEndTime" name="MultiEndTime" type="time" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                    </div>
                                    <div id="datePreviewContainer" class="bg-blue-50 p-4 rounded hidden">
                                        <div id="eventPreviewList" class="text-sm"></div>
                                        <p class="text-xs mt-2"><span id="eventCount">0</span> events total</p>
                                    </div>
                                </div>
                            </div>


                            <div class="flex justify-end space-x-3 pt-5 border-t">
                                <a href="@Url.Action("EventsForToday", "Events")" class="px-4 py-2 text-gray-700 hover:text-gray-900 transition-colors">Exit</a>

                                <button type="button" id="cancelChildBtn" onclick="hideChildEventForm()" class="hidden px-4 py-2 text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors">Cancel</button>
                                <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded-md shadow hover:bg-indigo-700 transition-colors">Create Event</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="successMessage" class="hidden mb-6 bg-green-50 border-l-4 border-green-500 p-4 rounded-md shadow-sm">
    <div class="flex items-center">
        <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
        </div>
        <div class="ml-3">
            <p class="text-sm text-green-700 font-medium">Event created successfully!</p>
            @if (ViewBag.HasMasterEvents == false)
            {}
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // --- Elements ---
            const form = document.getElementById('createEventForm');
            const modeRadios = document.getElementsByName('eventMode');
            const parentEventSection = document.getElementById('parentEventSection');
            const multiDayToggleContainer = document.getElementById('multiDayToggleContainer');
            const isMultiDay = document.getElementById('isMultiDay');
            
            // Container that wraps all input fields to easily show/hide them
            const eventDetailsWrapper = document.getElementById('eventDetailsWrapper');
            const cancelChildBtn = document.getElementById('cancelChildBtn');
            const subEventsListContainer = document.getElementById('subEventsListContainer');
            
            // Venue Elements
            const venueSearch = document.getElementById('venueSearch');
            const venueResultsList = document.getElementById('venueSearchResults');
            const venueHiddenInput = document.getElementById('VenueId');
            const clearVenueBtn = document.getElementById('clearVenueSelection');
            const subAreaSelect = document.getElementById('subAreaSelect');

            const childImageNote = document.getElementById('childImageNote');
            const parentError = document.getElementById('parentRequiredError'); 
            const searchInput = document.getElementById('parentEventSearch');
            const resultsList = document.getElementById('searchResults');
            const hiddenIdInput = document.getElementById('ParentEventId');
            const clearBtn = document.getElementById('clearParentSelection');
            const eventTypeSelect = document.getElementById('EventTypeId');

            const startInput = document.querySelector('input[name="StartDateTime"]:not([type="hidden"])');
            const endInput = document.querySelector('input[name="EndTime"]:not([type="hidden"])');
            const multiStartDate = document.getElementById('StartDate');
            const multiEndDate = document.getElementById('EndDate');
            const multiStartTime = document.getElementById('StartTime');
            const multiDailyEndTime = document.getElementById('DailyEndTime');

            const singleDayContainer = document.getElementById('singleDayContainer');
            const multiDayContainer = document.getElementById('multiDayContainer');

            const allScheduleInputs = [startInput, endInput, multiStartDate, multiEndDate, multiStartTime, multiDailyEndTime];

            window.showChildEventForm = function() {
                eventDetailsWrapper.classList.remove('hidden');
                cancelChildBtn.classList.remove('hidden'); // Show cancel button
                document.getElementById('Name').focus();
                window.scrollTo({top: eventDetailsWrapper.offsetTop - 50, behavior: 'smooth'});
            };

            window.hideChildEventForm = function() {
                eventDetailsWrapper.classList.add('hidden');
            };

            // --- 1. Mode Logic ---
            window.toggleEventMode = function(mode) {
                const isFather = (mode === 'father');
                multiDayToggleContainer.classList.toggle('hidden', isFather);
                if(childImageNote) childImageNote.classList.toggle('hidden', isFather);

                if (isFather) {
                    eventDetailsWrapper.classList.remove('hidden'); 
                    cancelChildBtn.classList.add('hidden'); 
                    
                    // Hide the sub-events table when in Master Mode
                    document.getElementById('subEventsListContainer').classList.add('hidden');
                    
                    venueSearch.disabled = false;
                    if(venueHiddenInput.value) clearVenueBtn.classList.remove('hidden');
                    subAreaSelect.disabled = false;
                    allScheduleInputs.forEach(i => i.disabled = false);
                    isMultiDay.checked = false;
                    singleDayContainer.classList.remove('hidden');
                    multiDayContainer.classList.add('hidden');
                    if(parentError) parentError.classList.add('hidden');
                    eventTypeSelect.disabled = false;
                    resetDateConstraints();
                    
                    isMultiDay.disabled = false;
                    document.querySelector('label[for="isMultiDay"]').classList.remove('text-gray-400');
                } else {
                    hideChildEventForm(); 
                    
                    // Show the table if we have a parent selected
                    if (document.getElementById('ParentEventId').value) {
                        document.getElementById('subEventsListContainer').classList.remove('hidden');
                    }
                    
                    if(venueSearch) venueSearch.disabled = true;
                    if(clearVenueBtn) clearVenueBtn.classList.add('hidden');
                    subAreaSelect.disabled = true;
                    eventTypeSelect.disabled = true;
                    allScheduleInputs.forEach(i => { if(i) i.disabled = true; });
                }
                updateRadioStyles();
            };

            function updateRadioStyles() {
                const masterRadio = document.getElementById('radioFather');
                const childRadio = document.getElementById('radioChild');
                const labelF = document.getElementById('labelFather');
                const labelC = document.getElementById('labelChild');

                // Reset styles
                labelF.className = "flex-1 text-center py-2 transition-all rounded-md";
                labelC.className = "flex-1 text-center py-2 transition-all rounded-md";
                labelF.querySelector('span').className = "font-medium";
                labelC.querySelector('span').className = "font-medium flex items-center justify-center";

                // Master Radio Styles
                if (masterRadio.disabled) {
                    labelF.classList.add('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
                    labelF.querySelector('span').classList.add('text-white');
                } else if (masterRadio.checked) {
                    labelF.classList.add('cursor-pointer', 'bg-white', 'shadow-sm');
                    labelF.querySelector('span').classList.add('text-indigo-700', 'font-bold');
                } else {
                    labelF.classList.add('cursor-pointer');
                    labelF.querySelector('span').classList.add('text-white');
                }

                // Child Radio Styles
                if (childRadio.disabled) {
                    labelC.classList.add('cursor-not-allowed', 'transition-all', 'rounded-md', 'opacity-50', 'pointer-events-none');
                    labelC.querySelector('span').classList.add('text-white');
                } else if (childRadio.checked) {
                    labelC.classList.add('cursor-pointer', 'bg-white', 'shadow-sm');
                    labelC.querySelector('span').classList.add('text-indigo-700', 'font-bold');
                } else {
                    labelC.classList.add('cursor-pointer');
                    labelC.querySelector('span').classList.add('text-white');
                }
            }

            // --- Constraint Helper ---
            async function applyParentTimingConstraints(parentId) {
                if (!parentId) return;
                try {
                    const response = await fetch(`/Events/GetEventTiming?id=${parentId}`);
                    if (!response.ok) throw new Error("Failed to fetch parent timing.");
                    const timing = await response.json();

                    const minISO = timing.start;
                    const maxISO = timing.end;
                    const minD = minISO.split('T')[0];
                    const maxD = maxISO.split('T')[0];

                    startInput.min = minISO; startInput.max = maxISO;
                    endInput.min = minISO; endInput.max = maxISO;
                    multiStartDate.min = minD; multiStartDate.max = maxD;
                    multiEndDate.min = minD; multiEndDate.max = maxD;
                    
                    multiStartTime.value = minISO.split('T')[1].substring(0, 5);
                    multiDailyEndTime.value = maxISO.split('T')[1].substring(0, 5);

                    if (minD === maxD) {
                        isMultiDay.checked = false;
                        isMultiDay.disabled = true;
                        document.querySelector('label[for="isMultiDay"]').classList.add('text-gray-400');
                        singleDayContainer.classList.remove('hidden');
                        multiDayContainer.classList.add('hidden');
                    } else {
                        isMultiDay.disabled = false;
                        document.querySelector('label[for="isMultiDay"]').classList.remove('text-gray-400');
                    }
                    if (isMultiDay.checked) updatePreview();
                } catch (err) { console.error("Error applying constraints:", err); }
            }

            // --- 2. Parent Event Selection ---
            async function selectParent(ev) {
                hiddenIdInput.value = ev.id;
                searchInput.value = ev.name;
                searchInput.disabled = true;
                clearBtn.classList.remove('hidden');
                resultsList.classList.add('hidden');
                if(parentError) parentError.classList.add('hidden');

                subEventsListContainer.classList.remove('hidden');
                hideChildEventForm(); 
                updateSubEventsList(ev.id);

                // Auto-fill venue from parent
                venueHiddenInput.value = ev.venueId;
                venueSearch.value = ev.venue || 'Inherited Venue'; 
                venueSearch.disabled = true;
                clearVenueBtn.classList.add('hidden'); 
                subAreaSelect.disabled = false;
                eventTypeSelect.value = ev.eventTypeId;
                eventTypeSelect.disabled = true;
                fetchSubAreas(ev.venueId);

                allScheduleInputs.forEach(i => i.disabled = false);
                resetDateConstraints();
                await applyParentTimingConstraints(ev.id);
            }

            searchInput.addEventListener('input', function(e) {
                if (e.target.value.length < 2) { resultsList.classList.add('hidden'); return; }
                fetch(`/Events/SearchParentEvents?query=${encodeURIComponent(e.target.value)}`)
                    .then(res => res.json())
                    .then(data => {
                        resultsList.innerHTML = '';
                        data.forEach(ev => {
                            const li = document.createElement('li');
                            li.className = 'p-3 hover:bg-indigo-50 cursor-pointer border-b text-sm';
                            li.innerHTML = `<strong>${ev.name}</strong><br><small>${ev.venue} | ${ev.date}</small>`;
                            li.onclick = () => selectParent(ev);
                            resultsList.appendChild(li);
                        });
                        resultsList.classList.remove('hidden');
                    });
            });

            clearBtn.onclick = () => {
                hiddenIdInput.value = ''; searchInput.value = ''; searchInput.disabled = false;
                clearBtn.classList.add('hidden'); 
                if(document.getElementById('radioChild').checked) {
                    venueHiddenInput.value = "";
                    venueSearch.value = "";
                    clearVenueBtn.classList.add('hidden');
                    subAreaSelect.disabled = true;
                    subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
                    allScheduleInputs.forEach(i => i.disabled = true);
                }
                isMultiDay.disabled = false;
                document.querySelector('label[for="isMultiDay"]').classList.remove('text-gray-400');
                resetDateConstraints();
            };

            // --- 3. Venue Selection ---
            venueSearch.addEventListener('input', function(e) {
                if (e.target.value.length < 2) { venueResultsList.classList.add('hidden'); return; }
                fetch(`/Events/SearchVenues?query=${encodeURIComponent(e.target.value)}`)
                    .then(res => res.json())
                    .then(data => {
                        venueResultsList.innerHTML = '';
                        data.forEach(v => {
                            const li = document.createElement('li');
                            li.className = 'p-3 hover:bg-indigo-50 cursor-pointer border-b text-sm';
                            li.innerHTML = `<strong>${v.name}</strong><br><small>${v.city || ''}</small>`;
                            li.onclick = () => {
                                venueHiddenInput.value = v.id;
                                venueSearch.value = v.name + (v.city ? ', ' + v.city : '');
                                venueSearch.disabled = true;
                                clearVenueBtn.classList.remove('hidden');
                                venueResultsList.classList.add('hidden');
                                fetchSubAreas(v.id);
                            };
                            venueResultsList.appendChild(li);
                        });
                        venueResultsList.classList.remove('hidden');
                    });
            });

            clearVenueBtn.onclick = () => {
                venueHiddenInput.value = '';
                venueSearch.value = '';
                venueSearch.disabled = false;
                clearVenueBtn.classList.add('hidden');
                subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
            };

            function fetchSubAreas(vId) {
                if(!vId) return;
                fetch(`/Events/GetSubAreas?venueId=${vId}`)
                    .then(res => res.json())
                    .then(data => {
                        subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
                        data.forEach(s => {
                            const opt = document.createElement('option');
                            opt.value = s.id; opt.textContent = s.areaName;
                            subAreaSelect.appendChild(opt);
                        });
                    });
            }

            function resetDateConstraints() {
                allScheduleInputs.forEach(i => { 
                    i.removeAttribute('min'); 
                    i.removeAttribute('max'); 
                });

                const now = new Date();
                const tzOffset = now.getTimezoneOffset() * 60000;
                const localISOTime = (new Date(now - tzOffset)).toISOString().slice(0, 16);
                const later = new Date(now.getTime() + (2 * 60 * 60 * 1000));
                const localISOLater = (new Date(later - tzOffset)).toISOString().slice(0, 16);

                startInput.value = localISOTime;
                endInput.value = localISOLater;
                
                const todayDate = localISOTime.split('T')[0];
                multiStartDate.value = todayDate;
                multiEndDate.value = todayDate;
            }

            isMultiDay.onchange = function() {
                singleDayContainer.classList.toggle('hidden', this.checked);
                multiDayContainer.classList.toggle('hidden', !this.checked);
                if(this.checked) updatePreview();
            };

            function enforceParentConstraints() {
                if (!document.getElementById('radioChild').checked || !hiddenIdInput.value) return;

                const minISO = startInput.getAttribute('min');
                const maxISO = startInput.getAttribute('max');

                // 1. Correct Single Day (datetime-local)
                if (minISO && startInput.value < minISO) startInput.value = minISO;
                if (maxISO && startInput.value > maxISO) startInput.value = maxISO;
                if (minISO && endInput.value < minISO) endInput.value = minISO;
                if (maxISO && endInput.value > maxISO) endInput.value = maxISO;

                // 2. Correct Multi Day Dates
                if (multiStartDate.min && multiStartDate.value < multiStartDate.min) multiStartDate.value = multiStartDate.min;
                if (multiStartDate.max && multiStartDate.value > multiStartDate.max) multiStartDate.value = multiStartDate.max;
                if (multiEndDate.min && multiEndDate.value < multiEndDate.min) multiEndDate.value = multiEndDate.min;
                if (multiEndDate.max && multiEndDate.value > multiEndDate.max) multiEndDate.value = multiEndDate.max;

                // 3. Correct Multi Day Times (Only constrained on the edge days)
                const pStartTime = minISO ? minISO.split('T')[1].substring(0, 5) : null;
                const pEndTime = maxISO ? maxISO.split('T')[1].substring(0, 5) : null;

                if (pStartTime && multiStartDate.value === multiStartDate.min) {
                    if (multiStartTime.value < pStartTime) multiStartTime.value = pStartTime;
                }
                if (pEndTime && multiEndDate.value === multiEndDate.max) {
                    if (multiDailyEndTime.value > pEndTime) multiDailyEndTime.value = pEndTime;
                }
            }

            function updatePreview() {
                enforceParentConstraints();

                const s = new Date(multiStartDate.value + 'T00:00:00');
                const e = new Date(multiEndDate.value + 'T00:00:00');

                const cont = document.getElementById('datePreviewContainer');
                if (isNaN(s.getTime()) || isNaN(e.getTime()) || s > e) { 
                    cont.classList.add('hidden'); 
                    return; 
                }
                
                let list = ""; let count = 0;
                for (let d = new Date(s); d <= e; d.setDate(d.getDate() + 1)) {
                    list += `<div class="py-1 border-b border-blue-100 last:border-0">
                                <span class="font-medium">${d.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' })}</span>
                             </div>`; 
                    count++;
                }
                document.getElementById('eventPreviewList').innerHTML = list;
                document.getElementById('eventCount').textContent = count;
                cont.classList.remove('hidden');
                
                document.getElementById('multiStartDateTime').value = `${multiStartDate.value}T${multiStartTime.value}`;
                document.getElementById('multiEndDateTime').value = `${multiEndDate.value}T${multiDailyEndTime.value}`;
            }
            [multiStartDate, multiEndDate, multiStartTime, multiDailyEndTime].forEach(i => i.oninput = updatePreview);

            [startInput, endInput].forEach(input => {
                input.addEventListener('change', function() {
                    if (document.getElementById('radioChild').checked && hiddenIdInput.value) {
                        if (this.min && this.value < this.min) this.value = this.min;
                        if (this.max && this.value > this.max) this.value = this.max;
                    }
                });
            });

            form.addEventListener('submit', async function(e) {
                e.preventDefault();

                // Run one final enforcement check to clean up any "half-typed" or browser-autofilled data
                enforceParentConstraints();

                // Validation checks
                const eventNameInput = document.getElementById('Name');
                if (!eventNameInput.value.trim()) {
                    alert("Please enter an Event Name.");
                    eventNameInput.focus();
                    return;
                }

                if (document.getElementById('radioChild').checked && !hiddenIdInput.value) {
                    if(parentError) parentError.classList.remove('hidden');
                    return;
                }
                
                if (!venueHiddenInput.value) {
                    alert("Please search and select a Venue from the dropdown list.");
                    venueSearch.focus();
                    return;
                }

                if (!subAreaSelect.value) {
                    alert("Please select a Sub Area.");
                    subAreaSelect.focus();
                    return;
                }

                if (isMultiDay.checked) {
                    const s = new Date(multiStartDate.value);
                    const e = new Date(multiEndDate.value);
                    if (isNaN(s) || isNaN(e) || s > e) { alert("Please select a valid date range."); return; }
                } else {
                    const s = new Date(startInput.value);
                    const e = new Date(endInput.value);
                    if (isNaN(s) || isNaN(e) || s >= e) { alert("Event must end after it starts."); return; }
                }

                if (document.getElementById('radioChild').checked && hiddenIdInput.value) {
                    const parentMin = startInput.getAttribute('min');
                    const parentMax = startInput.getAttribute('max');
                    
                    if (parentMin && parentMax) {
                        const pStart = new Date(parentMin);
                        const pEnd = new Date(parentMax);
                        
                        if (isMultiDay.checked) {
                            const firstInstanceStart = new Date(`${multiStartDate.value}T${multiStartTime.value}`);
                            const lastInstanceEnd = new Date(`${multiEndDate.value}T${multiDailyEndTime.value}`);
                            if (firstInstanceStart < pStart || lastInstanceEnd > pEnd) {
                                alert(`Sub-events must stay entirely within the Master Event's timeframe.\n\nMaster Event Limits:\nStarts: ${pStart.toLocaleString()}\nEnds: ${pEnd.toLocaleString()}`);
                                return;
                            }
                        } else {
   
                            const childStart = new Date(startInput.value);
                            const childEnd = new Date(endInput.value);
                            
                            if (childStart < pStart || childEnd > pEnd) {
                                alert(`Sub-events must stay entirely within the Master Event's timeframe.\n\nMaster Event Limits:\nStarts: ${pStart.toLocaleString()}\nEnds: ${pEnd.toLocaleString()}`);
                                return;
                            }
                        }
                    }
                }

                // Temporarily re-enable locked fields so FormData picks them up
                allScheduleInputs.forEach(i => { if(i) i.disabled = false; });
                if (eventTypeSelect) eventTypeSelect.disabled = false;
                if (subAreaSelect) subAreaSelect.disabled = false;

                const formData = new FormData(form);
                const submitBtn = form.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.innerHTML;

                try {
                    submitBtn.innerHTML = 'Creating...';
                    submitBtn.disabled = true;

                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                    });

                    if (!response.ok) {
                        const errorData = await response.json().catch(() => ({ message: "A server error occurred (500)." }));
                        throw new Error(errorData.message || "Failed to create event.");
                    }

                    if (true) { 
                        const data = await response.json(); 
                        const successAlert = document.getElementById('successMessage');
                        const alertText = successAlert.querySelector('p'); 
                        successAlert.classList.remove('hidden');
                        
                        const wasMasterEvent = document.getElementById('radioFather').checked;
                        
                        // Capture context before reset
                        const currentParentId = wasMasterEvent ? data.eventId : hiddenIdInput.value;
                        const currentParentName = wasMasterEvent ? data.eventName : searchInput.value;
                        const currentVenueId = wasMasterEvent ? data.venueId : venueHiddenInput.value;
                        const currentVenueName = wasMasterEvent ? (data.venueName || venueSearch.value) : venueSearch.value;
                        const currentEventTypeId = wasMasterEvent ? data.eventTypeId : eventTypeSelect.value;
                        
                        form.reset();
                        document.getElementById('imagePreviewContainer').classList.add('hidden');
                        document.getElementById('imagePreview').src = '#';
                        
                        // Clear Custom Search UI logic
                        venueHiddenInput.value = '';
                        venueSearch.value = '';
                        venueSearch.disabled = false;
                        clearVenueBtn.classList.add('hidden');
                        subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
                        
                        if (wasMasterEvent) {
                            alertText.textContent = "Master Event created! You can now quickly add Sub-Events for it.";
                            
                            const childLabel = document.getElementById('labelChild');
                            const childRadio = childLabel.querySelector('input');
                            
                            if (childRadio && childRadio.disabled) {
                                childRadio.disabled = false;
                                childLabel.removeAttribute('title');

                                childLabel.innerHTML = `
                                    <input type="radio" id="radioChild" name="eventMode" value="child" class="sr-only" onchange="toggleEventMode('child')">
                                    <span class="text-white font-medium">Sub-Event (Child)</span>
                                `;
                                const helperText = document.getElementById('parentUnlockHelperText');
                                if (helperText) helperText.classList.add('hidden');
                            }
                            
                            // Lock the master radio button
                            const masterRadio = document.getElementById('radioFather');
                            masterRadio.disabled = true;
                            masterRadio.checked = false;
                            
                            const newlyUnlockedRadio = document.getElementById('radioChild');
                            newlyUnlockedRadio.checked = true;
                            toggleEventMode('child');
                            

                            hideChildEventForm(); 


                            hiddenIdInput.value = data.eventId;
                            searchInput.value = data.eventName;
                            searchInput.disabled = true;          
                            clearBtn.classList.remove('hidden');  
                            resultsList.classList.add('hidden');  
                            
                            // Auto-fill Venue in Child Mode
                            venueHiddenInput.value = data.venueId;
                            venueSearch.value = data.venueName || 'Inherited Venue';
                            venueSearch.disabled = true;
                            clearVenueBtn.classList.add('hidden');
                            subAreaSelect.disabled = false;
                            fetchSubAreas(data.venueId);

                            // Lock Event Type in Child Mode
                            if (eventTypeSelect) {
                                eventTypeSelect.value = data.eventTypeId;
                                eventTypeSelect.disabled = true;
                            }

                            allScheduleInputs.forEach(i => { if(i) i.disabled = false; });
                            resetDateConstraints();
                            await applyParentTimingConstraints(data.eventId);
                            updateSubEventsList(currentParentId);
                            
                        } else {
                            alertText.textContent = "Sub-Event created successfully! Add another one if needed.";
                            

                            hideChildEventForm(); 

                            // Restore context for the next sub-event
                            hiddenIdInput.value = currentParentId;
                            searchInput.value = currentParentName;
                            searchInput.disabled = true;
                            clearBtn.classList.remove('hidden');
                            
                            venueHiddenInput.value = currentVenueId;
                            venueSearch.value = currentVenueName;
                            venueSearch.disabled = true;
                            
                            if (eventTypeSelect) {
                                eventTypeSelect.value = currentEventTypeId;
                                eventTypeSelect.disabled = true;
                            }
                            
                            subAreaSelect.disabled = false;
                            fetchSubAreas(currentVenueId);
                            updateSubEventsList(currentParentId);
                        }
                        
                        setTimeout(() => {
                            successAlert.classList.add('hidden');
                        }, 5000);
                    }
                } catch (error) {
                    console.error("Submission failed:", error);
                    alert(error.message || "A network error occurred. Please check your connection.");
                } finally {
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                    
                    if (document.getElementById('radioChild').checked && !hiddenIdInput.value) {
                        allScheduleInputs.forEach(i => { if(i) i.disabled = true; });
                    }
                }
            });

            toggleEventMode('father');
        });

        async function updateSubEventsList(parentId) {
            if (!parentId) return;
            try {
                const res = await fetch(`/Events/GetSubEvents?parentId=${parentId}`);
                const data = await res.json();
                
                const tbody = document.getElementById('subEventsTableBody');
                const counter = document.getElementById('subEventCountDisplay');
                const container = document.getElementById('subEventsListContainer');
                
                tbody.innerHTML = '';
                counter.textContent = data.length;

                container.classList.remove('hidden'); 
                
                if (data.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="3" class="px-6 py-4 text-center text-sm text-gray-500 italic">No sub-events created yet. Click the + button above to add one.</td></tr>`;
                    return;
                }

                data.forEach(ev => {
                    const row = document.createElement('tr');
                    row.className = 'hover:bg-gray-50 transition-colors';
                    
                    row.innerHTML = `
                        <td class="px-6 py-3 whitespace-nowrap">
                            <div class="font-bold text-gray-900">${ev.name}</div>
                        </td>
                        <td class="px-6 py-3 whitespace-nowrap">
                            <div class="font-medium text-gray-700">${ev.date}</div>
                            <div class="text-xs text-indigo-600 font-medium mt-0.5">${ev.time}</div>
                        </td>
                        <td class="px-6 py-3 whitespace-nowrap">
                            <div class="font-bold text-gray-900">${ev.layout}</div>
                        </td>
                        <td class="px-6 py-3 whitespace-nowrap text-right text-sm font-medium flex justify-end items-center gap-2">
                            <button type="button" onclick="deleteSubEvent(${ev.id})" class="text-red-500 hover:text-red-700 p-1 rounded-full hover:bg-red-50 transition-colors" title="Delete this instance">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                </svg>
                            </button>
                            <button type="button" onclick="DuplicateSubEvent(${ev.id})" class="text-indigo-600 hover:text-indigo-900 p-1 rounded-full hover:bg-indigo-50 transition-colors" title="Duplicate this instance">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v6h4a1 1 0 110 2h-4v6a1 1 0 11-2 0v-6H4a1 1 0 110-2h4V4a1 1 0 011-1z" clip-rule="evenodd" />
                                </svg>
                            </button>
                        </td>`;
                    tbody.appendChild(row);
                });
            } catch (e) { 
                console.error("Error updating list", e); 
            }
        }

        async function deleteSubEvent(id) {
            if (!confirm("Are you sure you want to delete this specific sub-event?")) return;
            try {
                const res = await fetch(`/Events/Delete?id=${id}&dAll=false`);
                if (res.ok) updateSubEventsList(document.getElementById('ParentEventId').value);
            } catch (e) { console.error("Error deleting", e); }
        }

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { 
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreviewContainer').classList.remove('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        async function DuplicateSubEvent(id) {
            if (!confirm("Are you sure you want to duplicate this specific sub-event?")) return;
            try {
                const res = await fetch(`/Events/DuplicateSubEvent?id=${id}`, {
                    method: 'POST'
                });
                if (res.ok) updateSubEventsList(document.getElementById('ParentEventId').value);
            } catch (e) { console.error("Error duplicating", e);        
        }
        }
    </script>
}