@model PtixiakiReservations.Models.Event

@{
    ViewData["Title"] = "Create New Event";
}

<div class="bg-gradient-to-r from-blue-50 to-indigo-50 min-h-screen py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-xl shadow-md overflow-hidden mb-8">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-8">
                <h1 class="text-2xl md:text-3xl font-bold text-white">Create New Event</h1>
                <p class="mt-2 text-indigo-100 max-w-3xl">
                    Schedule new events for your venue, set up recurring events or create single instances
                </p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <div class="p-6">
                <form method="post" id="createEventForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="space-y-6">
                        
                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                            <div class="flex items-center mb-4">
                                <div class="h-10 w-10 rounded-md bg-indigo-100 flex items-center justify-center text-indigo-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                </div>
                                <h2 class="ml-3 text-lg font-medium text-gray-800">Event Information</h2>
                            </div>

                            <div class="bg-indigo-600 rounded-lg p-1 mb-6 flex shadow-inner">
                            <label class="flex-1 text-center py-2 cursor-pointer transition-all rounded-md bg-white shadow-sm" id="labelFather">
                                <input type="radio" name="eventMode" value="father" class="sr-only" checked onchange="toggleEventMode('father')">
                                <span class="text-indigo-700 font-bold">Master Event</span>
                            </label>

                            <label class="flex-1 text-center py-2 cursor-not-allowed transition-all rounded-md opacity-50 pointer-events-none" id="labelChild" title="You must create a Master Event first!">
                                <input type="radio" name="eventMode" value="child" class="sr-only" disabled>
                                <span class="text-white font-medium flex items-center justify-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                    </svg>
                                    Sub-Event (Child)
                                </span>
                            </label>
                        </div>

                        <p id="unlockHelperText" class="text-sm text-indigo-500 font-medium mt-1 text-right italic">
                            * Create a Master Event first to unlock Sub-Events
                        </p>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Event Name</label>
                                    <input asp-for="Name" placeholder="Enter event name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500"/>
                                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
                                </div>
                                <div>
                                    <label asp-for="EventTypeId" class="block text-sm font-medium text-gray-700 mb-1">Event Type</label>
                                    <select asp-for="EventTypeId" asp-items="ViewBag.EventTypeList" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white"></select>
                                </div>
                            </div>
                        </div>

                        <div id="parentEventSection" class="hidden bg-gray-50 rounded-lg p-4 border border-gray-200">
                            <h2 class="text-lg font-medium text-gray-800 mb-4">Parent Event Selection</h2>
                            <input type="hidden" asp-for="ParentEventId" id="ParentEventId" name="ParentEventId" />
                            <div class="search-container relative max-w-md">
                                <label class="text-sm font-medium text-gray-700">Search Father Event</label>
                                <div class="flex gap-2">
                                    <input type="text" id="parentEventSearch" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white" placeholder="Start typing..." autocomplete="off" />
                                    <button class="px-4 py-2 bg-gray-200 rounded-md text-sm hidden" type="button" id="clearParentSelection">Clear</button>
                                </div>
                                <ul id="searchResults" class="absolute w-full bg-white border rounded-b-lg shadow-xl z-50 hidden max-h-60 overflow-y-auto"></ul>
                            </div>
                            <p id="parentRequiredError" class="text-red-500 text-xs mt-2 hidden font-bold">You must select a father event to continue in child mode!</p>
                        </div>

                        <div class="mt-6">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Event Poster</label>
                            <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg bg-white">
                                <div class="text-center">
                                    <label for="imageFile" class="cursor-pointer font-medium text-indigo-600">
                                        <span>Upload a file</span>
                                        <input id="imageFile" name="imageFile" type="file" class="sr-only" accept="image/*" onchange="previewImage(this)">
                                    </label>
                                    <p id="childImageNote" class="hidden text-indigo-500 text-xs italic mt-1">Inherits Father's image if left empty</p>
                                </div>
                            </div>
                            <div id="imagePreviewContainer" class="hidden mt-4">
                                <img id="imagePreview" src="#" class="h-32 w-auto rounded-lg shadow-sm border">
                            </div>
                        </div>

                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <!-- NEW VENUE SEARCH -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Venue</label>
                                    <input type="hidden" asp-for="VenueId" id="VenueId" />
                                    <div class="search-container relative">
                                        <div class="flex gap-2">
                                            <input type="text" id="venueSearch" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white disabled:bg-gray-100 disabled:text-gray-400" placeholder="Search for a venue..." autocomplete="off" />
                                            <button class="px-4 py-2 bg-gray-200 rounded-md text-sm hidden" type="button" id="clearVenueSelection">Clear</button>
                                        </div>
                                        <ul id="venueSearchResults" class="absolute w-full bg-white border rounded-b-lg shadow-xl z-50 hidden max-h-60 overflow-y-auto"></ul>
                                    </div>
                                </div>
                                <div>
                                    <label asp-for="SubAreaId" class="block text-sm font-medium text-gray-700 mb-1">Sub Area</label>
                                    <select asp-for="SubAreaId" id="subAreaSelect" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white disabled:bg-gray-100" required>
                                        <option value="">Select a sub area</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                            <div id="multiDayToggleContainer" class="flex items-center mb-6">
                                <input type="checkbox" id="isMultiDay" name="IsMultiDay" class="h-5 w-5 text-indigo-600 border-gray-300 rounded">
                                <label for="isMultiDay" class="ml-3 font-medium text-gray-700">Create events for multiple days</label>
                            </div>

                            <div id="singleDayContainer" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <input asp-for="StartDateTime" type="datetime-local" class="w-full border p-2 rounded-lg disabled:bg-gray-100" />
                                <input asp-for="EndTime" type="datetime-local" class="w-full border p-2 rounded-lg disabled:bg-gray-100" />
                            </div>

                            <div id="multiDayContainer" class="hidden space-y-6">
                                <input asp-for="StartDateTime" type="hidden" id="multiStartDateTime" />
                                <input asp-for="EndTime" type="hidden" id="multiEndDateTime" />
                                <div class="grid grid-cols-2 gap-4">
                                    <input id="StartDate" type="date" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                    <input id="EndDate" type="date" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                    <input id="StartTime" type="time" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                    <input id="DailyEndTime" type="time" class="border p-2 rounded-lg disabled:bg-gray-100" />
                                </div>
                                <div id="datePreviewContainer" class="bg-blue-50 p-4 rounded hidden">
                                    <div id="eventPreviewList" class="text-sm"></div>
                                    <p class="text-xs mt-2"><span id="eventCount">0</span> events total</p>
                                </div>
                            </div>
                        </div>

                        <div class="flex justify-end space-x-3 pt-5 border-t">
                            <a href="@Url.Action("EventsForToday", "Events")" class="px-4 py-2 text-gray-700">Exit</a>
                            <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded-md">Create Event</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="successMessage" class="hidden mb-6 bg-green-50 border-l-4 border-green-500 p-4 rounded-md shadow-sm">
    <div class="flex items-center">
        <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
        </div>
        <div class="ml-3">
            <p class="text-sm text-green-700 font-medium">Event created successfully!</p>
            @if (ViewBag.HasMasterEvents == false)
            {
                <p id="unlockHelperText" class="text-sm text-indigo-500 font-medium mt-1 text-right italic">
                    * Create a Master Event first to unlock Sub-Events
                </p>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // --- Elements ---
            const form = document.getElementById('createEventForm');
            const modeRadios = document.getElementsByName('eventMode');
            const parentEventSection = document.getElementById('parentEventSection');
            const multiDayToggleContainer = document.getElementById('multiDayToggleContainer');
            const isMultiDay = document.getElementById('isMultiDay');
            
            // Venue Elements
            const venueSearch = document.getElementById('venueSearch');
            const venueResultsList = document.getElementById('venueSearchResults');
            const venueHiddenInput = document.getElementById('VenueId');
            const clearVenueBtn = document.getElementById('clearVenueSelection');
            const subAreaSelect = document.getElementById('subAreaSelect');

            const childImageNote = document.getElementById('childImageNote');
            const parentError = document.getElementById('parentRequiredError'); 
            const searchInput = document.getElementById('parentEventSearch');
            const resultsList = document.getElementById('searchResults');
            const hiddenIdInput = document.getElementById('ParentEventId');
            const clearBtn = document.getElementById('clearParentSelection');

            const startInput = document.querySelector('input[name="StartDateTime"]:not([type="hidden"])');
            const endInput = document.querySelector('input[name="EndTime"]:not([type="hidden"])');
            const multiStartDate = document.getElementById('StartDate');
            const multiEndDate = document.getElementById('EndDate');
            const multiStartTime = document.getElementById('StartTime');
            const multiDailyEndTime = document.getElementById('DailyEndTime');

            const singleDayContainer = document.getElementById('singleDayContainer');
            const multiDayContainer = document.getElementById('multiDayContainer');

            const allScheduleInputs = [startInput, endInput, multiStartDate, multiEndDate, multiStartTime, multiDailyEndTime];

            // --- 1. Mode Logic ---
            window.toggleEventMode = function(mode) {
                const isFather = (mode === 'father');
                multiDayToggleContainer.classList.toggle('hidden', isFather);
                if(childImageNote) childImageNote.classList.toggle('hidden', isFather);

                if (isFather) {
                    venueSearch.disabled = false;
                    if(venueHiddenInput.value) clearVenueBtn.classList.remove('hidden');
                    subAreaSelect.disabled = false;
                    allScheduleInputs.forEach(i => i.disabled = false);
                    isMultiDay.checked = false;
                    singleDayContainer.classList.remove('hidden');
                    multiDayContainer.classList.add('hidden');
                    if(parentError) parentError.classList.add('hidden');
                    resetDateConstraints();
                } else {
                    venueSearch.disabled = true;
                    clearVenueBtn.classList.add('hidden');
                    subAreaSelect.disabled = true;
                    allScheduleInputs.forEach(i => i.disabled = true);
                }
                updateRadioStyles();
            };

            function updateRadioStyles() {
                const isFather = modeRadios[0].checked;
                const labelF = document.getElementById('labelFather');
                const labelC = document.getElementById('labelChild');
                const childRadio = labelC.querySelector('input');

                if (isFather) {
                    labelF.className = "flex-1 text-center py-2 cursor-pointer transition-all rounded-md bg-white shadow-sm";
                    labelF.querySelector('span').className = "text-indigo-700 font-bold";
                    
                    if (childRadio.disabled) {
                        labelC.className = "flex-1 text-center py-2 cursor-not-allowed transition-all rounded-md opacity-50";
                        labelC.querySelector('span').className = "text-white font-medium flex items-center justify-center";
                    } else {
                        labelC.className = "flex-1 text-center py-2 cursor-pointer transition-all rounded-md";
                        labelC.querySelector('span').className = "text-white font-medium";
                    }
                } else {
                    labelC.className = "flex-1 text-center py-2 cursor-pointer transition-all rounded-md bg-white shadow-sm";
                    labelC.querySelector('span').className = "text-indigo-700 font-bold";
                    
                    labelF.className = "flex-1 text-center py-2 cursor-pointer transition-all rounded-md";
                    labelF.querySelector('span').className = "text-white font-medium";
                }
            }

            // --- 2. Parent Event Selection ---
            function selectParent(ev) {
                hiddenIdInput.value = ev.id;
                searchInput.value = ev.name;
                searchInput.disabled = true;
                clearBtn.classList.remove('hidden');
                resultsList.classList.add('hidden');
                if(parentError) parentError.classList.add('hidden');

                // Auto-fill venue from parent
                venueHiddenInput.value = ev.venueId;
                venueSearch.value = ev.venue || 'Inherited Venue'; 
                venueSearch.disabled = true;
                clearVenueBtn.classList.add('hidden'); // Child cannot clear inherited venue
                subAreaSelect.disabled = false;
                fetchSubAreas(ev.venueId);

                allScheduleInputs.forEach(i => i.disabled = false);
                resetDateConstraints();

                if (ev.rawStartDate && ev.rawEndDate) {
                    const minD = ev.rawStartDate.split('T')[0];
                    const maxD = ev.rawEndDate.split('T')[0];
                    startInput.min = ev.rawStartDate; startInput.max = ev.rawEndDate;
                    endInput.min = ev.rawStartDate; endInput.max = ev.rawEndDate;
                    multiStartDate.min = minD; multiStartDate.max = maxD;
                    multiEndDate.min = minD; multiEndDate.max = maxD;
                    
                    multiStartTime.value = ev.rawStartDate.split('T')[1].substring(0,5);
                    multiDailyEndTime.value = ev.rawEndDate.split('T')[1].substring(0,5);
                }
                if (isMultiDay.checked) updatePreview();
            }

            searchInput.addEventListener('input', function(e) {
                if (e.target.value.length < 2) { resultsList.classList.add('hidden'); return; }
                fetch(`/Events/SearchParentEvents?query=${encodeURIComponent(e.target.value)}`)
                    .then(res => res.json())
                    .then(data => {
                        resultsList.innerHTML = '';
                        data.forEach(ev => {
                            const li = document.createElement('li');
                            li.className = 'p-3 hover:bg-indigo-50 cursor-pointer border-b text-sm';
                            li.innerHTML = `<strong>${ev.name}</strong><br><small>${ev.venue} | ${ev.date}</small>`;
                            li.onclick = () => selectParent(ev);
                            resultsList.appendChild(li);
                        });
                        resultsList.classList.remove('hidden');
                    });
            });

            clearBtn.onclick = () => {
                hiddenIdInput.value = ''; searchInput.value = ''; searchInput.disabled = false;
                clearBtn.classList.add('hidden'); 
                if(modeRadios[1].checked) {
                    venueHiddenInput.value = "";
                    venueSearch.value = "";
                    clearVenueBtn.classList.add('hidden');
                    subAreaSelect.disabled = true;
                    subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
                    allScheduleInputs.forEach(i => i.disabled = true);
                }
                resetDateConstraints();
            };

            // --- 3. Venue Selection ---
            venueSearch.addEventListener('input', function(e) {
                if (e.target.value.length < 2) { venueResultsList.classList.add('hidden'); return; }
                fetch(`/Events/SearchVenues?query=${encodeURIComponent(e.target.value)}`)
                    .then(res => res.json())
                    .then(data => {
                        venueResultsList.innerHTML = '';
                        data.forEach(v => {
                            const li = document.createElement('li');
                            li.className = 'p-3 hover:bg-indigo-50 cursor-pointer border-b text-sm';
                            li.innerHTML = `<strong>${v.name}</strong><br><small>${v.city || ''}</small>`;
                            li.onclick = () => {
                                venueHiddenInput.value = v.id;
                                venueSearch.value = v.name;
                                venueSearch.disabled = true;
                                clearVenueBtn.classList.remove('hidden');
                                venueResultsList.classList.add('hidden');
                                fetchSubAreas(v.id);
                            };
                            venueResultsList.appendChild(li);
                        });
                        venueResultsList.classList.remove('hidden');
                    });
            });

            clearVenueBtn.onclick = () => {
                venueHiddenInput.value = '';
                venueSearch.value = '';
                venueSearch.disabled = false;
                clearVenueBtn.classList.add('hidden');
                subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
            };

            function fetchSubAreas(vId) {
                if(!vId) return;
                fetch(`/Events/GetSubAreas?venueId=${vId}`)
                    .then(res => res.json())
                    .then(data => {
                        subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
                        data.forEach(s => {
                            const opt = document.createElement('option');
                            opt.value = s.id; opt.textContent = s.areaName;
                            subAreaSelect.appendChild(opt);
                        });
                    });
            }

            function resetDateConstraints() {
                allScheduleInputs.forEach(i => { 
                    i.removeAttribute('min'); 
                    i.removeAttribute('max'); 
                });

                const now = new Date();
                const tzOffset = now.getTimezoneOffset() * 60000;
                const localISOTime = (new Date(now - tzOffset)).toISOString().slice(0, 16);
                const later = new Date(now.getTime() + (2 * 60 * 60 * 1000));
                const localISOLater = (new Date(later - tzOffset)).toISOString().slice(0, 16);

                startInput.value = localISOTime;
                endInput.value = localISOLater;
                
                const todayDate = localISOTime.split('T')[0];
                multiStartDate.value = todayDate;
                multiEndDate.value = todayDate;
            }

            isMultiDay.onchange = function() {
                singleDayContainer.classList.toggle('hidden', this.checked);
                multiDayContainer.classList.toggle('hidden', !this.checked);
                if(this.checked) updatePreview();
            };

            function updatePreview() {
                const s = new Date(multiStartDate.value);
                const e = new Date(multiEndDate.value);
                const cont = document.getElementById('datePreviewContainer');
                if (isNaN(s) || isNaN(e) || s > e) { cont.classList.add('hidden'); return; }
                
                let list = ""; let count = 0;
                for (let d = new Date(s); d <= e; d.setDate(d.getDate() + 1)) {
                    list += `<div>${d.toLocaleDateString()}</div>`; count++;
                }
                document.getElementById('eventPreviewList').innerHTML = list;
                document.getElementById('eventCount').textContent = count;
                cont.classList.remove('hidden');
                
                document.getElementById('multiStartDateTime').value = `${multiStartDate.value}T${multiStartTime.value}`;
                document.getElementById('multiEndDateTime').value = `${multiEndDate.value}T${multiDailyEndTime.value}`;
            }
            [multiStartDate, multiEndDate, multiStartTime, multiDailyEndTime].forEach(i => i.onchange = updatePreview);

            form.addEventListener('submit', async function(e) {
                e.preventDefault();

                if (modeRadios[1].checked && !hiddenIdInput.value) {
                    if(parentError) parentError.classList.remove('hidden');
                    return;
                }
                
                if (!venueHiddenInput.value) {
                    alert("Please search and select a Venue from the dropdown list.");
                    return;
                }

                allScheduleInputs.forEach(i => i.disabled = false);

                const formData = new FormData(form);
                const submitBtn = form.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.innerHTML;

                try {
                    submitBtn.innerHTML = 'Creating...';
                    submitBtn.disabled = true;

                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                    });

                    if (response.ok) {
                        const data = await response.json(); 
                        const successAlert = document.getElementById('successMessage');
                        const alertText = successAlert.querySelector('p'); 
                        successAlert.classList.remove('hidden');
                        
                        const wasMasterEvent = modeRadios[0].checked;
                        
                        form.reset();
                        document.getElementById('imagePreviewContainer').classList.add('hidden');
                        document.getElementById('imagePreview').src = '#';
                        
                        // Clear Custom Search UI logic
                        venueHiddenInput.value = '';
                        venueSearch.value = '';
                        venueSearch.disabled = false;
                        clearVenueBtn.classList.add('hidden');
                        subAreaSelect.innerHTML = '<option value="">Select a sub area</option>';
                        
                        if (wasMasterEvent) {
                            alertText.textContent = "Master Event created! You can now quickly add Sub-Events for it.";
                            
                            const childLabel = document.getElementById('labelChild');
                            const childRadio = childLabel.querySelector('input');
                            
                            if (childRadio && childRadio.disabled) {
                                childRadio.disabled = false;
                                childLabel.classList.remove('cursor-not-allowed', 'opacity-50', 'pointer-events-none');
                                childLabel.classList.add('cursor-pointer');
                                childLabel.removeAttribute('title');

                                childLabel.innerHTML = `
                                    <input type="radio" name="eventMode" value="child" class="sr-only" onchange="toggleEventMode('child')">
                                    <span class="text-white font-medium">Sub-Event (Child)</span>
                                `;
                                const helperText = document.getElementById('unlockHelperText');
                                if (helperText) helperText.classList.add('hidden');
                            }
                            
                            const newlyUnlockedRadio = document.querySelector('input[name="eventMode"][value="child"]');
                            newlyUnlockedRadio.checked = true;
                            toggleEventMode('child');
                            
                            hiddenIdInput.value = data.eventId;
                            searchInput.value = data.eventName;
                            searchInput.disabled = true;          
                            clearBtn.classList.remove('hidden');  
                            resultsList.classList.add('hidden');  
                            
                            // Auto-fill Venue in Child Mode
                            venueHiddenInput.value = data.venueId;
                            venueSearch.value = data.venueName || 'Inherited Venue';
                            venueSearch.disabled = true;
                            clearVenueBtn.classList.add('hidden');
                            subAreaSelect.disabled = false;
                            fetchSubAreas(data.venueId);

                            allScheduleInputs.forEach(i => i.disabled = false);
                            resetDateConstraints();

                            const eventTypeSelect = document.getElementById('EventTypeId');
                            if (eventTypeSelect) {
                                eventTypeSelect.value = data.eventTypeId;
                            }
                            
                        } else {
                            alertText.textContent = "Sub-Event created successfully! Add another one if needed.";
                        }
                        
                        setTimeout(() => {
                            successAlert.classList.add('hidden');
                        }, 5000);
                    }
                } catch (error) {
                    console.error("Error submitting form:", error);
                    alert("A network error occurred. Please try again.");
                } finally {
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                    
                    if (modeRadios[1].checked && !hiddenIdInput.value) {
                        allScheduleInputs.forEach(i => i.disabled = true);
                    }
                }
            });

            toggleEventMode('father');
        });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { 
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreviewContainer').classList.remove('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}