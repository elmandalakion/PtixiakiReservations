@page
@model ResetPasswordWith2faModel
@{
    ViewData["Title"] = "2FA Verification";
}

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white dark:bg-gray-800 shadow-xl rounded-2xl p-8 text-center">

    <!-- Icon -->
    <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-blue-100 dark:bg-blue-900">
      <svg class="h-8 w-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor"
           viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 11c0-1.657 1.343-3 3-3s3 1.343 3 3v2a3 3 0 11-6 0v-2zM6 11v2a6 6 0 0012 0v-2" />
      </svg>
    </div>

    <!-- Title -->
    <h2 class="mt-4 text-2xl font-bold text-gray-800 dark:text-white">
      2FA Verification
    </h2>

    <!-- Subtitle -->
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
      Enter the 6-digit code from your authenticator app to confirm your password reset.
    </p>

    <form method="post" id="otpForm" class="mt-6 space-y-5">

      <div asp-validation-summary="All" class="text-red-500 text-sm"></div>

      <!-- OTP INPUT -->
      <input type="text" name="TwoFactorCode" id="otpInput"
        inputmode="numeric"
        maxlength="6"
        autocomplete="one-time-code"
        placeholder="000000"
        class="w-full text-center text-2xl tracking-[0.5em] border border-gray-300 rounded-xl py-3 
               focus:outline-none focus:ring-2 focus:ring-blue-500
               dark:bg-gray-700 dark:border-gray-600 dark:text-white" required />

      <!-- Error (optional custom) -->
      <p id="otpError" class="hidden text-red-500 text-sm">
        Invalid code. Try again.
      </p>

      <!-- Submit -->
      <button id="submitBtn" type="submit"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-xl transition">
        Verify & Reset Password
      </button>

    </form>

    <!-- Extra info -->
    <p class="mt-4 text-xs text-gray-400">
      Didn’t receive a code? Check your authenticator app.
    </p>

  </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />

<script>
const form = document.getElementById("otpForm");
const btn = document.getElementById("submitBtn");
const input = document.getElementById("otpInput");

// ⏳ Loading state
form.addEventListener("submit", () => {
    btn.disabled = true;
    btn.innerText = "Verifying...";
});

// 🔢 Auto restrict to numbers only
input.addEventListener("input", () => {
    input.value = input.value.replace(/\D/g, '');
});

// ⌨️ Enter submit (extra safety)
input.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
        form.submit();
    }
});
</script>
}