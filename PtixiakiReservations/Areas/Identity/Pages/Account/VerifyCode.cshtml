@page
@model PtixiakiReservations.Areas.Identity.Pages.Account.VerifyCodeModel

@{
    ViewData["Title"] = "Verificiation";
}

<div class="container mx-auto mt-10 px-4">
    <div class="flex justify-center">
        <div class="w-full max-w-md">
            <section class="bg-white p-6 rounded-lg shadow-md">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    
                    <input type="hidden" asp-for="ReturnUrl" />
                    <input type="hidden" asp-for="Input.RememberMe" />

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Code" class="form-control block w-full mt-1 px-4 py-2 border border-gray-300 rounded-lg 
                                        focus:ring focus:ring-blue-200 focus:outline-none pr-10
                                        transition-all duration-200" autocomplete="off" placeholder="123456" />
                        <label asp-for="Input.Code">Security Code</label>
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>
                    
                    <button type="submit" class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700 focus:ring focus:ring-blue-200 transition duration-200">Verify and Log in</button>
                </form>
            </section>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</div>