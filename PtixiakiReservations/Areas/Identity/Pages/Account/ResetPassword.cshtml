@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white dark:bg-gray-800 shadow-xl rounded-2xl p-8">

    <!-- Title -->
    <h1 class="text-2xl font-bold text-gray-800 dark:text-white text-center">
      Reset Password
    </h1>

    <p class="text-sm text-gray-500 dark:text-gray-400 text-center mt-2">
      Enter your new password below
    </p>

    <!-- Success Message -->
    <div id="successBox" class="hidden mt-4 text-green-600 text-sm text-center font-medium">
      Password changed successfully! Redirecting...
    </div>

    <form method="post" id="resetForm" class="mt-6 space-y-5">

      <div asp-validation-summary="All" class="text-red-500 text-sm"></div>

      <input asp-for="Input.Code" type="hidden" />

      <!-- Email -->
      <div>
        <label asp-for="Input.Email"
          class="block text-sm font-medium text-gray-600 dark:text-gray-300 mb-1"></label>

        <input asp-for="Input.Email"
          class="w-full px-3 py-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" />

        <span asp-validation-for="Input.Email"
          class="text-red-500 text-sm"></span>
      </div>

      <!-- Password -->
      <div>
        <label asp-for="Input.Password"
          class="block text-sm font-medium text-gray-600 dark:text-gray-300 mb-1"></label>

        <div class="relative">
          <input asp-for="Input.Password" type="password" id="passwordInput"
            class="w-full px-3 py-2 border border-gray-300 rounded-xl pr-10 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" />

          <!-- Eye -->
          <button type="button" onclick="togglePassword('passwordInput', this)"
            class="absolute right-2 top-2 text-gray-500">
            👁
          </button>
        </div>

        <!-- Strength Bar -->
        <div class="mt-2 h-2 bg-gray-200 rounded">
          <div id="strengthBar" class="h-2 rounded transition-all"></div>
        </div>

        <span asp-validation-for="Input.Password"
          class="text-red-500 text-sm"></span>
      </div>

      <!-- Confirm Password -->
      <div>
        <label asp-for="Input.ConfirmPassword"
          class="block text-sm font-medium text-gray-600 dark:text-gray-300 mb-1"></label>

        <div class="relative">
          <input asp-for="Input.ConfirmPassword" type="password" id="confirmPasswordInput"
            class="w-full px-3 py-2 border border-gray-300 rounded-xl pr-10 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white" />

          <button type="button" onclick="togglePassword('confirmPasswordInput', this)"
            class="absolute right-2 top-2 text-gray-500">
            👁
          </button>
        </div>

        <span asp-validation-for="Input.ConfirmPassword"
          class="text-red-500 text-sm"></span>
      </div>

      <!-- Submit -->
      <button id="submitBtn" type="submit"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-xl transition flex items-center justify-center">
        Reset Password
      </button>

    </form>
  </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />

<script>
const form = document.getElementById("resetForm");
const btn = document.getElementById("submitBtn");
const passwordInput = document.getElementById("passwordInput");
const strengthBar = document.getElementById("strengthBar");

// 🔐 Show / Hide password
function togglePassword(id, el) {
    const input = document.getElementById(id);
    input.type = input.type === "password" ? "text" : "password";
}

// 🔥 Password strength
passwordInput.addEventListener("input", () => {
    const val = passwordInput.value;
    let strength = 0;

    if (val.length > 5) strength++;
    if (val.match(/[A-Z]/)) strength++;
    if (val.match(/[0-9]/)) strength++;
    if (val.match(/[^A-Za-z0-9]/)) strength++;

    const widths = ["0%", "25%", "50%", "75%", "100%"];
    const colors = ["", "bg-red-500", "bg-yellow-500", "bg-blue-500", "bg-green-500"];

    strengthBar.style.width = widths[strength];
    strengthBar.className = "h-2 rounded " + colors[strength];
});

// ⏳ Loading state
form.addEventListener("submit", () => {
    btn.disabled = true;
    btn.innerHTML = "Resetting...";
});

// (OPTIONAL) Αν θες fake success πριν redirect
// Μπορείς να το ενεργοποιήσεις αν κάνεις AJAX αντί για normal POST
</script>
}