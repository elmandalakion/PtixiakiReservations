@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white dark:bg-gray-800 shadow-xl rounded-2xl p-8 text-center">

    <!-- Success Icon -->
    <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100 dark:bg-green-900">
      <svg class="h-8 w-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor"
           viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <!-- Title -->
    <h1 class="mt-4 text-2xl font-bold text-gray-800 dark:text-white">
      Password Reset Successful
    </h1>

    <!-- Message -->
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
      Your password has been successfully reset. You can now log in with your new credentials.
    </p>

    <!-- CTA Button -->
    <a asp-page="./Login"
       class="mt-6 inline-block w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-xl transition">
      Go to Login
    </a>

    <!-- Optional secondary link -->
    <p class="mt-4 text-xs text-gray-400">
      Didn’t request this? You may want to secure your account.
    </p>

  </div>
</div>